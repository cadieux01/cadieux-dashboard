{
  "git": {
    "deploymentEnabled": {
      "gh-pages": false
    }
  },
  "rewrites": [
    { "source": "/dashboard/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/dashboard", "destination": "/index.html" },
    { "source": "/dashboard/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/dashboard",
      "headers": [{ "key": "Cache-Control", "value": "no-store, must-revalidate" }]
    },
    {
      "source": "/dashboard/:path((?!assets/).*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store, must-revalidate" }]
    }
  ]
}
